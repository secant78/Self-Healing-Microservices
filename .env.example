# ═══════════════════════════════════════════════════════════════════
#  Self-Healing Microservices — Environment Variables
#  Copy this file to .env and fill in values for local development.
#  NEVER commit .env to version control.
# ═══════════════════════════════════════════════════════════════════

# ── Shared ───────────────────────────────────────────────────────────────────
# OpenTelemetry — points to Jaeger when running via docker-compose
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# Azure Application Insights (leave empty to use Jaeger only locally)
APPLICATIONINSIGHTS_CONNECTION_STRING=

# ── Frontend (Node.js) ───────────────────────────────────────────────────────
PORT=3000
ORDER_SERVICE_URL=http://localhost:8080

# ── Order Service (.NET) ──────────────────────────────────────────────────────
PAYMENT_SERVICE_URL=http://localhost:8000
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://+:8080

# ── Payment Service (Python) ──────────────────────────────────────────────────
# No extra vars needed beyond shared ones above

# ── Self-Healing Azure Function ───────────────────────────────────────────────
AZURE_SUBSCRIPTION_ID=your-subscription-id
RESOURCE_GROUP_NAME=rg-self-healing-microservices
DEFAULT_CONTAINER_APP_NAME=ca-payment-service
# PAYMENT_SERVICE_URL is shared above

# ── Azure Container Registry (CI/CD) ─────────────────────────────────────────
ACR_NAME=your-acr-name
ACR_LOGIN_SERVER=your-acr-name.azurecr.io

# ── Azure OIDC (GitHub Actions) ───────────────────────────────────────────────
AZURE_CLIENT_ID=
AZURE_TENANT_ID=
AZURE_SUBSCRIPTION_ID=
